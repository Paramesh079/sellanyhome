{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Real Estate Data Exploratory Data Analysis (EDA)\n",
    "\n",
    "This notebook reads all the CSV files from the `data` directory and performs basic EDA on each."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "\n",
    "plt.style.use('ggplot')\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "pd.set_option('display.max_columns', None)\n",
    "\n",
    "data_dir = 'data'\n",
    "files = [f for f in os.listdir(data_dir) if f.endswith('.csv')]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Brokers Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_brokers = pd.read_csv(os.path.join(data_dir, 'brokers-2026-03-04.csv'))\n",
    "display(df_brokers.head(3))\n",
    "print(f\"Rows: {df_brokers.shape[0]}, Columns: {df_brokers.shape[1]}\")\n",
    "print(\"\\nMissing Values:\\n\", df_brokers.isna().sum().sum())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(8, 4))\n",
    "sns.countplot(data=df_brokers, x='GENDER_EN', palette='Set2')\n",
    "plt.title('Distribution of Brokers by Gender')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Buildings Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_buildings = pd.read_csv(os.path.join(data_dir, 'buildings-2026-03-04.csv'))\n",
    "display(df_buildings.head(3))\n",
    "print(f\"Rows: {df_buildings.shape[0]}, Columns: {df_buildings.shape[1]}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10, 5))\n",
    "top_areas = df_buildings['AREA_EN'].value_counts().head(10)\n",
    "sns.barplot(x=top_areas.values, y=top_areas.index, palette='Blues_r')\n",
    "plt.title('Top 10 Areas by Number of Buildings')\n",
    "plt.xlabel('Count')\n",
    "plt.show()\n",
    "\n",
    "plt.figure(figsize=(6, 4))\n",
    "sns.countplot(data=df_buildings, x='IS_FREE_HOLD_EN', palette='blend:#7AB,#EDA')\n",
    "plt.title('Free Hold vs Non-Free Hold Buildings')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Lands Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_lands = pd.read_csv(os.path.join(data_dir, 'lands-2026-03-04.csv'))\n",
    "display(df_lands.head(3))\n",
    "print(f\"Rows: {df_lands.shape[0]}, Columns: {df_lands.shape[1]}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(10, 5))\n",
    "top_land_types = df_lands['PROP_SUB_TYPE_EN'].value_counts().head(10)\n",
    "sns.barplot(x=top_land_types.values, y=top_land_types.index, palette='Greens_r')\n",
    "plt.title('Top 10 Land Types')\n",
    "plt.xlabel('Count')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Rents Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_rents = pd.read_csv(os.path.join(data_dir, 'rents-2026-03-04.csv'))\n",
    "display(df_rents.head(3))\n",
    "print(f\"Rows: {df_rents.shape[0]}, Columns: {df_rents.shape[1]}\")\n",
    "\n",
    "df_rents['ANNUAL_AMOUNT'] = pd.to_numeric(df_rents['ANNUAL_AMOUNT'], errors='coerce')\n",
    "df_rents = df_rents.dropna(subset=['ANNUAL_AMOUNT'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(8, 5))\n",
    "sns.countplot(data=df_rents, y='USAGE_EN', order=df_rents['USAGE_EN'].value_counts().index, palette='Oranges_r')\n",
    "plt.title('Rental Contracts by Usage Type')\n",
    "plt.show()\n",
    "\n",
    "# Filter out crazy outliers for rent distribution plot\n",
    "q95 = df_rents['ANNUAL_AMOUNT'].quantile(0.95)\n",
    "q05 = df_rents['ANNUAL_AMOUNT'].quantile(0.05)\n",
    "filtered_rents = df_rents[(df_rents['ANNUAL_AMOUNT'] < q95) & (df_rents['ANNUAL_AMOUNT'] > q05)]\n",
    "\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.histplot(filtered_rents['ANNUAL_AMOUNT'], bins=50, kde=True, color='coral')\n",
    "plt.title('Distribution of Annual Rent Amounts (Middle 90%)')\n",
    "plt.xlabel('Annual Amount (AED)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Transactions Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_transactions = pd.read_csv(os.path.join(data_dir, 'transactions-2026-03-04.csv'))\n",
    "display(df_transactions.head(3))\n",
    "print(f\"Rows: {df_transactions.shape[0]}, Columns: {df_transactions.shape[1]}\")\n",
    "\n",
    "df_transactions['TRANS_VALUE'] = pd.to_numeric(df_transactions['TRANS_VALUE'], errors='coerce')\n",
    "df_transactions = df_transactions.dropna(subset=['TRANS_VALUE'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(8, 5))\n",
    "sns.countplot(data=df_transactions, y='GROUP_EN', order=df_transactions['GROUP_EN'].value_counts().index, palette='Purples_r')\n",
    "plt.title('Transactions by Group (Sales, Mortgages, etc.)')\n",
    "plt.show()\n",
    "\n",
    "top_trans_areas = df_transactions.groupby('AREA_EN')['TRANS_VALUE'].sum().sort_values(ascending=False).head(10)\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.barplot(x=top_trans_areas.values, y=top_trans_areas.index, palette='magma')\n",
    "plt.title('Top 10 Areas by Total Transaction Value')\n",
    "plt.xlabel('Total Value')\n",
    "plt.ylabel('Area')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Valuations Data EDA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_valuations = pd.read_csv(os.path.join(data_dir, 'valuations-2026-03-04.csv'))\n",
    "display(df_valuations.head(3))\n",
    "print(f\"Rows: {df_valuations.shape[0]}, Columns: {df_valuations.shape[1]}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(6, 4))\n",
    "sns.countplot(data=df_valuations, x='PROPERTY_TYPE_EN', palette='Pastel1')\n",
    "plt.title('Valuations by Property Type')\n",
    "plt.show()"
   ]
  }
 ],
